aws_region = "us-east-1"
key_name   = "cs312-key"

# Replace with your public IP /32 before terraform apply.
admin_cidr_blocks = ["REPLACE_WITH_YOUR_PUBLIC_IP/32"]

# Required public Minecraft port. Restrict to your IP /32 if you only need testing.
minecraft_cidr_blocks = ["0.0.0.0/0"]

instance_type        = "t3.medium"
root_volume_size_gb  = 40
iam_instance_profile = "LabInstanceProfile"
